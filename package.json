{
  "name": "aloha-desktop",
  "version": "1.0.30-alpha",
  "description": "Desktop AI Agent with tool calling capabilities",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "AlohaDesktop.com",
  "homepage": "https://alohadesktop.com",
  "repository": "https://github.com/aloha-desktop/aloha-desktop",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "test": "npm run test:plugins && npm run test:models && npm run test:unit",
    "test:plugins": "node -e \"JSON.stringify(require('./plugins.json'))\"",
    "test:models": "node -e \"JSON.stringify(require('./models.json'))\"",
    "test:unit": "vitest run",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && npm run rebuild",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "rebuild": "electron-rebuild -f -w better-sqlite3,bufferutil,utf-8-validate"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.1.0",
    "bufferutil": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9",
    "jimp": "^1.6.1",
    "utf-8-validate": "^6.0.6"
  },
  "devDependencies": {
    "@cacheable/node-cache": "^3.0.0",
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^3.7.2",
    "@iconify-json/radix-icons": "^1.2.2",
    "@iconify/vue": "^5.0.0",
    "@mdit/plugin-img-size": "^0.22.2",
    "@shikijs/markdown-it": "^3.7.0",
    "@tailwindcss/vite": "^4.1.10",
    "@tanstack/vue-table": "^8.21.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.14.1",
    "@types/qrcode": "^1.5.6",
    "@types/tar": "^6.1.13",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vueuse/core": "^13.7.0",
    "aloha-sdk": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.20",
    "electron-ollama": "^0.1.25",
    "electron-vite": "^3.1.0",
    "eslint": "^9.24.0",
    "eslint-plugin-vue": "^10.0.0",
    "lucide-vue-next": "^0.515.0",
    "markdown-it": "^14.1.0",
    "markdown-it-async": "^2.2.0",
    "marked": "^16.0.0",
    "mime-types": "^3.0.1",
    "ollama": "^0.5.16",
    "pinia": "^3.0.3",
    "prettier": "^3.5.3",
    "qrcode": "^1.5.4",
    "reka-ui": "^2.4.1",
    "shiki": "^3.7.0",
    "shiki-header-with-copy": "^1.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.10",
    "tar": "^7.4.3",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.6",
    "vitest": "^4.1.5",
    "vue": "^3.5.17",
    "vue-async-component-provider": "^0.4.1",
    "vue-eslint-parser": "^10.1.3",
    "vue-router": "^4.5.1",
    "vue-sonner": "^2.0.2",
    "vue-tsc": "^2.2.8"
  }
}
